# LLM provider: "gemini" (default) or "groq"
LLM_PROVIDER=gemini

# Google Gemini (free tier via Google AI Studio)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (free tier, alternate provider — only needed if LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Tavily web search (free tier)
TAVILY_API_KEY=
